# OpenAI API key — required for LLM features (gpt-5-nano)
# Get yours at https://platform.openai.com/account/api-keys
OPENAI_API_KEY=sk-...

# gpt-5-nano pricing (per 1K tokens) — $0.05/$0.005/$0.40 per 1M input/cached/output
GPT5_NANO_INPUT_COST_PER_1K=0.00005
GPT5_NANO_CACHED_COST_PER_1K=0.000005
GPT5_NANO_OUTPUT_COST_PER_1K=0.0004

# ── Bot settings ──────────────────────────────────────────────────────────────
# GitHub token for fetching live PR data (required for openclaw strategy)
GITHUB_TOKEN=ghp_...

# WillItMerge market API
BOT_API_BASE_URL=http://127.0.0.1:8787
BOT_API_KEY=

# Strategy: 'openclaw' (ML model, default) or 'random' (for testing)
BOT_STRATEGY=openclaw

# Set to false for live trading; true = log trades without executing
BOT_DRY_RUN=true

# Loop and sizing
BOT_LOOP_MINUTES=10
BOT_MAX_WORKERS=20
BOT_MAX_TRADES_PER_CYCLE=5
BOT_MAX_SPEND_PER_CYCLE=50
BOT_EDGE_THRESHOLD=0.03
BOT_MAX_FRACTION_PER_MARKET=0.02
BOT_MAX_DOLLARS_PER_MARKET=25
BOT_MIN_DOLLARS_PER_TRADE=1
BOT_DEFAULT_BANKROLL=1000
